# General
NODE_ENV=development
APP_NAME=world-cup-prediction-platform
APP_DOMAIN=localhost
PUBLIC_BASE_URL=http://localhost

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api

# Backend
BACKEND_PORT=3001
API_PREFIX=api
JWT_SECRET=change_me_in_real_environment
JWT_EXPIRES_IN=15m
CORS_ORIGIN=http://localhost:3000
AUTH_COOKIE_SECURE=false
PRISMA_CONNECTION_LIMIT=4

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=world_cup_predictions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/world_cup_predictions?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Football-Data.org
FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=replace_with_api_key
FOOTBALL_DATA_ALLOW_INSECURE_TLS=false
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SYNC_INTERVAL_MINUTES=5

# Email / SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="World Cup Predictions <no-reply@example.com>"
SMTP_ALLOW_INSECURE_TLS=true
EMAIL_CODE_EXPIRES_MINUTES=15

# Monitoring
GRAFANA_ADMIN_PASSWORD=change_me

# Nginx
NGINX_PORT=80

# Production checklist values
# APP_DOMAIN=predicciones.example.com
# PUBLIC_BASE_URL=https://predicciones.example.com
# NEXT_PUBLIC_API_URL=https://predicciones.example.com/api
# CORS_ORIGIN=https://predicciones.example.com
# JWT_SECRET=<long-random-secret>
# AUTH_COOKIE_SECURE=true
# PRISMA_CONNECTION_LIMIT=4
# POSTGRES_PASSWORD=<strong-database-password>
# DATABASE_URL=postgresql://postgres:<strong-database-password>@postgres:5432/world_cup_predictions?schema=public&connection_limit=4&pool_timeout=10
# FOOTBALL_DATA_API_KEY=<football-data-api-key>
# SMTP_HOST=<smtp-host>
# SMTP_PORT=587
# SMTP_USER=<smtp-user>
# SMTP_PASS=<smtp-password>
# SMTP_FROM="World Cup Predictions <no-reply@example.com>"
# GRAFANA_ADMIN_PASSWORD=<strong-password>
