# General
NODE_ENV=development
APP_NAME=world-cup-prediction-platform

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost/api

# Backend
BACKEND_PORT=3001
API_PREFIX=api
JWT_SECRET=change_me_in_real_environment
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=world_cup_predictions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/world_cup_predictions?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Football-Data.org
FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
FOOTBALL_DATA_API_KEY=replace_with_api_key
FOOTBALL_DATA_ALLOW_INSECURE_TLS=false
FOOTBALL_DATA_COMPETITION=WC

# Email / SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="World Cup Predictions <no-reply@example.com>"
EMAIL_CODE_EXPIRES_MINUTES=15

# Nginx
NGINX_PORT=80
